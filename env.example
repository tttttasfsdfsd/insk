# ==================== EEXA Platform v4 — Environment Variables ====================
# Copy to .env and fill in real values. NEVER commit .env to version control.

# ---- App ----
NODE_ENV=development
PORT=3001
API_PORT=3001
APP_ID=eexa-platform

# ---- Security (REQUIRED in production — use 32+ random chars) ----
JWT_SECRET=CHANGE_ME_min32chars_use_openssl_rand_base64_32
JWT_REFRESH_SECRET=CHANGE_ME_different_from_jwt_secret_min32chars
SESSION_SECRET=CHANGE_ME_session_secret_min32chars

# ---- CORS (comma-separated origins) ----
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ---- AI Keys (at least one required for AI features) ----
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE
OPENAI_API_KEY=sk-YOUR_OPENAI_KEY_HERE

# ---- Database (required for production) ----
DATABASE_URL=mysql://user:password@localhost:3306/eexa_prod

# ---- Billing — Stripe ----
STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET
STRIPE_PRICE_PROFESSIONAL=price_YOUR_PROFESSIONAL_PRICE_ID
STRIPE_PRICE_BUSINESS=price_YOUR_BUSINESS_PRICE_ID

# ---- Billing — Moyasar (Saudi payments) ----
MOYASAR_SECRET_KEY=sk_live_YOUR_MOYASAR_KEY
MOYASAR_PUBLISHABLE_KEY=pk_live_YOUR_MOYASAR_KEY

# ---- QuickBooks OAuth ----
QB_CLIENT_ID=YOUR_QB_CLIENT_ID
QB_CLIENT_SECRET=YOUR_QB_CLIENT_SECRET
QB_REDIRECT_URI=https://your-domain.com/api/quickbooks/callback

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
ANALYZE_RATE_LIMIT_MAX=10

# ---- File Upload ----
MAX_FILE_SIZE_MB=25
